# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# Large originals — web-optimised copies live in assets/images/trips/ and assets/images/grad/
# Exclude raw source files directly in assets/images/; subfolders (trips/, grad/) are committed.
assets/images/*.jpeg
assets/images/*.jpg
assets/images/*.png
assets/images/*.HEIC
assets/images/*.heic
assets/images/*.dmg
assets/images/*.pdf
assets/images/*.docx
assets/images/~$*

# Drop-zone originals (root level — move to assets/ before committing)
/*.jpeg
/*.jpg
/*.HEIC
/new_resume.pdf
/*.pdf

# Claude local settings (may contain personal config)
.claude/settings.local.json

# Node (test runner only — no node_modules exist)
node_modules/

# Temp / lock files
~$*
*.tmp
